{# Formulaire complete (doneBy + contributions) - partagé entre subtask show et modale bulk close #}
{% set contributionPrototype %}
<div class="card border mb-2 shadow-sm" data-collection-type-target="item">
	<div class="card-body p-3">
		<div class="row g-2 align-items-center">
			<div class="col-12 col-lg-5 min-w-0">
				{{ form_widget(completeForm.contributions.vars.prototype.membership) }}
				{{ form_errors(completeForm.contributions.vars.prototype.membership) }}
			</div>
			<div class="col-12 col-lg">
				{{ form_widget(completeForm.contributions.vars.prototype.timeSpent) }}
				{{ form_errors(completeForm.contributions.vars.prototype.timeSpent) }}
			</div>
			<div class="col-12 col-lg-auto">
				<button type="button" class="btn btn-outline-danger" data-action="click->collection-type#removeItem click->contribution-total#refresh" title="{{ 'remove'|trans }}">
					<i class="ti ti-trash"></i>
				</button>
			</div>
		</div>
	</div>
</div>
{% endset %}

{# Who did the task - only show for managers (or always in modal via showDoneByFilter) #}
{% if showDoneByFilter|default(is_granted('MANAGE')) %}
	<div class="mb-3">
		{{ form_row(completeForm.doneBy) }}
	</div>
{% else %}
	<div style="display: none;">
		{{ form_row(completeForm.doneBy) }}
	</div>
{% endif %}

{# Contributions list #}
<div class="mb-3"
	{{ stimulus_controller('collection-type')|stimulus_controller('contribution-members-filter')|stimulus_controller('contribution-total') }}
	data-contribution-members-filter-all-membership-ids-value="{{ contributionAllMembershipIds|default([])|json_encode|e('html_attr') }}"
	data-contribution-members-filter-initial-used-membership-ids-value="{{ contributionUsedMembershipIds|default([])|json_encode|e('html_attr') }}"
	data-prototype="{{ contributionPrototype|e('html_attr') }}">
	{{ form_label(completeForm.contributions) }}
	<div data-collection-type-target="container" data-contribution-members-filter-target="container" data-contribution-total-target="container" data-initial-used-ids="{{ contributionUsedMembershipIds|default([])|join(',') }}">
		<div class="empty text-center text-secondary border rounded py-3 mb-2">
			<em>{{ 'noContributionInCompleteForm'|trans }}</em>
		</div>
		{% for contributionForm in completeForm.contributions %}
			<div class="card border mb-2 shadow-sm" data-collection-type-target="item">
				<div class="card-body p-3">
					<div class="row g-2 align-items-center">
						<div class="col-12 col-lg-5 min-w-0">
							{{ form_widget(contributionForm.membership) }}
							{{ form_errors(contributionForm.membership) }}
						</div>
						<div class="col-12 col-lg">
							{{ form_widget(contributionForm.timeSpent) }}
							{{ form_errors(contributionForm.timeSpent) }}
						</div>
						<div class="col-12 col-lg-auto">
							<button type="button" class="btn btn-outline-danger" data-action="click->collection-type#removeItem click->contribution-total#refresh" title="{{ 'remove'|trans }}">
								<i class="ti ti-trash"></i>
							</button>
						</div>
					</div>
				</div>
			</div>
		{% endfor %}
	</div>
	<button type="button" class="btn btn-outline-primary btn-sm mt-2" data-action="click->collection-type#addItem click->contribution-members-filter#refresh click->contribution-total#refresh" data-contribution-members-filter-target="addButton">
		<i class="ti ti-plus me-1"></i>
		{{ 'addContribution'|trans }}
	</button>
	{{ form_errors(completeForm.contributions) }}
	{% do completeForm.contributions.setRendered %}

	{# Total time (calculated from contributions) #}
	<div class="mt-3">
		<span class="text-secondary">{{ 'totalTime'|trans }}:</span>
		<strong data-contribution-total-target="total">{{ subTaskForTotal|default(subTask|default(null)) ? (subTaskForTotal|default(subTask)|format_time_spent) : '0 minute' }}</strong>
	</div>
</div>
