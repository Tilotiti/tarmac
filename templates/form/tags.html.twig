{% block tag_filter_row %}
	<div class="mb-3" data-controller="tag-filter">
		{{ form_label(form) }}

		{# Tag UI - clickable badges #}
		<div class="d-flex flex-wrap gap-2 mb-2">
			{% for choice in form %}
				{% set choiceValue = choice.vars.value %}
				{% set choiceLabel = choice.vars.label %}
				{% set isChecked = choice.vars.checked %}

				<span class="badge bg-secondary-lt text-white {% if isChecked %}active border border-2 border-secondary{% endif %}" data-tag-filter-target="tag" data-value="{{ choiceValue }}" data-action="click->tag-filter#toggle" style="cursor: pointer; transition: all 0.2s; user-select: none;">
					{{ choiceLabel|trans }}
					{% if isChecked %}
						<i class="ti ti-check ms-1"></i>
					{% endif %}
				</span>
			{% endfor %}
		</div>

		{# Hidden checkboxes - keep them for form submission #}
		<div style="display: none;">
			{% for choice in form %}
				<input type="checkbox" name="{{ choice.vars.full_name }}" value="{{ choice.vars.value }}" id="{{ choice.vars.id }}" {% if choice.vars.checked %} checked="checked" {% endif %} data-tag-filter-target="checkbox"/>
			{% endfor %}
		</div>
		{{ form_errors(form) }}
	</div>
{% endblock %}

{% block specialisation_tag_widget %}
	<div class="position-relative" data-controller="tag-manager">
		{{ form_widget(form, {
			attr: form.vars.attr|default({})|merge({
				'data-tag-manager-target': 'select'
			})
		}) }}
		<div data-tag-manager-target="tagsContainer" class="d-flex flex-wrap align-items-center mb-2 min-h-38"></div>
		<input type="text"
			class="form-control"
			data-tag-manager-target="input"
			placeholder="{{ 'searchSpecialisation'|trans }}..."
			autocomplete="off"
			aria-label="{{ 'searchSpecialisation'|trans }}">
		<div data-tag-manager-target="dropdown"
			class="list-group position-absolute start-0 end-0 mt-1 d-none border rounded shadow overflow-auto bg-white"
			style="max-height: 14rem; min-height: 2.5rem; z-index: 1050;"></div>
	</div>
{% endblock %}

